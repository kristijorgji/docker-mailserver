{{ ansible_managed | comment }}
{% if enable_mailbox_quotas | bool %}

protocol imap {
  mail_plugins = $mail_plugins quota imap_quota
}

protocol lmtp {
  mail_plugins = $mail_plugins quota
}

plugin {
  quota = dict:User quota::proxy::quota
  {# quota_warning needs an executable (e.g. `quota-warning 90 %u`). A bare
     `storage=90%%` rule makes IMAP die after auth with PREAUTH/(null). #}
}
{% endif %}
